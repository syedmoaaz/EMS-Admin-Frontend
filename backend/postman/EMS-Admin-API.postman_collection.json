{
  "info": {
    "name": "EMS Admin API",
    "description": "MediTrack EMS API collection. Import with EMS-Local environment.\n\nTest order: Health → Login → copy token to environment → run protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "branchId", "value": "" },
    { "key": "employeeId", "value": "" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Company Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.environment.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@novapharma.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/company/login"
          }
        },
        {
          "name": "Company Create",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.environment.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"ABC Pharma\",\n  \"ownerName\": \"Test Owner\",\n  \"email\": \"owner@abcpharma.com\",\n  \"password\": \"abc123456\",\n  \"phone\": \"03009999999\"\n}"
            },
            "url": "{{baseUrl}}/company/create"
          }
        }
      ]
    },
    {
      "name": "Company",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/company/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"NovaPharma Ltd.\",\n  \"ownerName\": \"Saad Karim\",\n  \"phone\": \"03001234567\"\n}"
            },
            "url": "{{baseUrl}}/company/update"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"admin123\",\n  \"newPassword\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/company/change-password"
          }
        }
      ]
    },
    {
      "name": "Branches",
      "item": [
        {
          "name": "Get All Branches",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data[0]) {",
                  "    pm.collectionVariables.set('branchId', json.data[0]._id);",
                  "    pm.environment.set('branchId', json.data[0]._id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/branches"
          }
        },
        {
          "name": "Create Branch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Branch\",\n  \"code\": \"TST-01\",\n  \"city\": \"Karachi\",\n  \"manager\": \"Test Manager\",\n  \"status\": \"Active\"\n}"
            },
            "url": "{{baseUrl}}/branches"
          }
        },
        {
          "name": "Get Branch By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/branches/{{branchId}}"
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get All Employees",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data[0]) {",
                  "    pm.collectionVariables.set('employeeId', json.data[0]._id);",
                  "    pm.environment.set('employeeId', json.data[0]._id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/employees"
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"EMP-TEST-01\",\n  \"name\": \"Test Employee\",\n  \"phone\": \"03001111111\",\n  \"branch\": \"{{branchId}}\",\n  \"designation\": \"Order Taker\",\n  \"department\": \"Sales\",\n  \"role\": \"Order Taker\",\n  \"status\": \"Active\"\n}"
            },
            "url": "{{baseUrl}}/employees"
          }
        },
        {
          "name": "Get Employee By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/employees/{{employeeId}}"
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Get Attendance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/attendance"
          }
        },
        {
          "name": "Get Attendance Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/attendance/stats"
          }
        },
        {
          "name": "Get Attendance History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/attendance/history/{{employeeId}}"
          }
        }
      ]
    },
    {
      "name": "Tracking",
      "item": [
        {
          "name": "Get Live Tracking",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/tracking/live"
          }
        },
        {
          "name": "Get Tracking Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/tracking/stats"
          }
        },
        {
          "name": "Get Employee Tracking",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/tracking/{{employeeId}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/stats"
          }
        }
      ]
    }
  ]
}
